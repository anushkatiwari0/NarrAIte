# ─────────────────────────────────────────────
# NarrAIte Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── OpenRouter ──────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model — gpt-4o-mini is fast & affordable; use gpt-4o for best quality
OPENAI_MODEL=gpt-4o-mini

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (for CORS) ──────────────────
FRONTEND_URL=http://localhost:5173

# ── Limits ──────────────────────────────────
# Max records per batch job
MAX_BATCH_SIZE=50

# Rate limit: max AI requests per 15 minutes per IP
RATE_LIMIT_MAX=50
